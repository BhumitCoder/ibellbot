# ── Telegram Bot ──────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Sarvam AI ─────────────────────────────────────────────────
# Get this from https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Firebase Service Account ───────────────────────────────────
# Go to Firebase Console → Project Settings → Service Accounts
# → Generate new private key → Download JSON
# Paste the ENTIRE JSON as a single line (minified) here:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"ibellmobiles-123","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@ibellmobiles-123.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Session Secret ─────────────────────────────────────────────
# Any long random string for admin session encryption
SESSION_SECRET=change-this-to-a-long-random-string

# ── Render Deployment ─────────────────────────────────────────
# After deploying on Render, paste your service URL here
WEBHOOK_URL=https://your-app-name.onrender.com

# ── Server Port (Render sets this automatically) ──────────────
PORT=3000
